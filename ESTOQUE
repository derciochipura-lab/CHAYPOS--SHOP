#include <stdio.h>
#include <string.h>

typedef struct {
    char nome[30];
    float preco;
    int qtd;
} Produto;

void exibirEstoque(Produto *p) {
    printf("\n--- ITEM NO SISTEMA ---\n");
    printf("Produto: %s\n", p->nome);
    printf("Preco: R$ %.2f\n", p->preco);
    printf("Quantidade: %d\n", p->qtd);
}

int main() {
    Produto loja[2];

    // Cadastro manual para teste
    strcpy(loja[0].nome, "Capa iPhone");
    loja[0].preco = 89.90;
    loja[0].qtd = 15;

    strcpy(loja[1].nome, "AirPods Pro");
    loja[1].preco = 1199.00;
    loja[1].qtd = 5;

    for(int i=0; i<2; i++) {
        exibirEstoque(&loja[i]);
    }

    return 0;
}
